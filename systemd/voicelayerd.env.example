# VoiceLayer daemon environment file.
#
# `scripts/install.sh` copies this template to
# ~/.config/voicelayer/voicelayerd.env the first time it runs, after which
# the daemon loads it via `EnvironmentFile=` in voicelayerd.service.
# Existing files are preserved on reinstall.
#
# Lines starting with `#` are comments. Uncomment and edit values to
# override defaults. Every variable is also described in
# docs/guides/systemd.md, which is the authoritative reference.
#
# Notes:
# - systemd EnvironmentFile does not expand `%h`, `%t`, or `${VAR}` in
#   values. Write absolute paths rather than shell-like substitutions.
# - The unit hardcodes `--socket-path %t/voicelayer/daemon.sock`, so
#   VOICELAYER_SOCKET_PATH is not consulted when running under systemd.

# --- Core -----------------------------------------------------------------

# Path to the repo so the daemon can locate the Python worker
# (python/voicelayer_orchestrator). Required.
VOICELAYER_PROJECT_ROOT=/absolute/path/to/voice-layer

# Per-call upper bound on worker JSON-RPC inference calls
# (transcribe, compose, rewrite, translate). Probes (health,
# list_providers) use a fixed 15s budget. Default: 600.
#VOICELAYER_WORKER_TIMEOUT_SECONDS=600

# Daemon socket path override. The systemd unit hardcodes
# --socket-path %t/voicelayer/daemon.sock, so this is only consulted
# when the daemon is launched outside systemd (e.g., `cargo run` or
# ad-hoc scripting) or when a CLI/vl-desktop process wants to reach a
# non-default socket. Default: $XDG_RUNTIME_DIR/voicelayer/daemon.sock.
#VOICELAYER_SOCKET_PATH=/run/user/1000/voicelayer/daemon.sock

# --- whisper.cpp ASR (one-shot whisper-cli) -------------------------------

# Path (or $PATH binary name) for whisper-cli.
VOICELAYER_WHISPER_BIN=whisper-cli
# Absolute path to a ggml model; example: ggml-base.en.bin.
VOICELAYER_WHISPER_MODEL_PATH=/absolute/path/to/ggml-base.en.bin
# Per-call timeout in seconds.
VOICELAYER_WHISPER_TIMEOUT_SECONDS=300
# Force CPU inference even when whisper-cli is built with GPU support.
# Truthy values: 1, true, yes, on.
VOICELAYER_WHISPER_NO_GPU=false
# Extra flags forwarded verbatim to whisper-cli.
VOICELAYER_WHISPER_ARGS=

# --- whisper.cpp ASR (persistent whisper-server) --------------------------
#
# Enable either by pointing at an externally-managed server
# (SERVER_HOST + SERVER_PORT) or by turning on autostart
# (SERVER_AUTO_START=1) with SERVER_BIN plus the shared
# VOICELAYER_WHISPER_MODEL_PATH declared above. When both whisper-cli
# and whisper-server are configured the daemon prefers the server; see
# docs/guides/local-asr-provider.md for the full selection rules and
# measured latency difference.

#VOICELAYER_WHISPER_SERVER_HOST=127.0.0.1
#VOICELAYER_WHISPER_SERVER_PORT=8188
#VOICELAYER_WHISPER_SERVER_TIMEOUT_SECONDS=60
#VOICELAYER_WHISPER_SERVER_AUTO_START=false
#VOICELAYER_WHISPER_SERVER_BIN=whisper-server
#VOICELAYER_WHISPER_SERVER_ARGS=
#VOICELAYER_WHISPER_SERVER_LAUNCH_TIMEOUT_SECONDS=30
#VOICELAYER_WHISPER_SERVER_POLL_INTERVAL_SECONDS=0.5

# --- whisper.cpp ASR (optional silero-vad pre-pass) -----------------------
#
# When enabled, the Python worker runs silero-vad before whisper to drop
# leading/trailing silence. Requires onnxruntime and a silero-vad ONNX
# model; see docs/guides/local-asr-provider.md for download and tuning.

#VOICELAYER_WHISPER_VAD_ENABLED=false
#VOICELAYER_WHISPER_VAD_MODEL_PATH=/absolute/path/to/silero_vad.onnx
#VOICELAYER_WHISPER_VAD_THRESHOLD=0.5
#VOICELAYER_WHISPER_VAD_MIN_SPEECH_MS=250
#VOICELAYER_WHISPER_VAD_MIN_SILENCE_MS=100
#VOICELAYER_WHISPER_VAD_SPEECH_PAD_MS=30
#VOICELAYER_WHISPER_VAD_MAX_SEGMENT_SECS=30
#VOICELAYER_WHISPER_VAD_SAMPLE_RATE=16000

# --- Xiaomi MiMo-V2.5-ASR (optional GPU provider) -------------------------
#
# Opt-in ASR backend for multilingual / quality-priority workflows.
# CUDA only (flash-attn requires CUDA 12 + Python 3.12); needs ~16 GB
# VRAM at bf16. The wrapper class lives in the upstream source tree
# and is not currently distributed as a wheel: clone
# https://github.com/XiaomiMiMo/MiMo-V2.5-ASR locally, set
# VOICELAYER_MIMO_REPO_PATH at the checkout, and install the heavy
# Python deps via the `mimo` extra
# (uv pip install --no-build-isolation -e ".[mimo]"). See
# docs/guides/local-asr-provider.md for the full bootstrap. Callers
# select this provider via TranscribeRequest.provider_id =
# "mimo_v2_5_asr"; whisper.cpp remains the default.

#VOICELAYER_MIMO_MODEL_PATH=/absolute/path/to/MiMo-V2.5-ASR
#VOICELAYER_MIMO_TOKENIZER_PATH=/absolute/path/to/MiMo-Audio-Tokenizer
#VOICELAYER_MIMO_REPO_PATH=/absolute/path/to/MiMo-V2.5-ASR-source-checkout
#VOICELAYER_MIMO_DEVICE=cuda:0
#VOICELAYER_MIMO_AUDIO_TAG=
#VOICELAYER_MIMO_TIMEOUT_SECONDS=600
#VOICELAYER_MIMO_LONG_AUDIO_SPLIT_SECONDS=180
#VOICELAYER_MIMO_ARGS=

# --- OpenAI-compatible LLM ------------------------------------------------

VOICELAYER_LLM_ENDPOINT=http://127.0.0.1:8080
VOICELAYER_LLM_MODEL=gemma-3-1b-it
VOICELAYER_LLM_API_KEY=
VOICELAYER_LLM_TIMEOUT_SECONDS=60

# --- llama-server autostart (optional) ------------------------------------
#
# Turn on AUTO_START=1 with LLAMA_SERVER_BIN and either LLAMA_MODEL_PATH
# or LLAMA_HF_REPO to have the daemon spawn llama-server lazily on the
# first compose/rewrite/translate call. Leaving AUTO_START unset (the
# default) means the daemon expects the LLM at VOICELAYER_LLM_ENDPOINT
# to be managed externally. The uncommented lines below are placeholders
# — edit paths before enabling or autostart will fail repeatedly.

#VOICELAYER_LLM_AUTO_START=true
#VOICELAYER_LLAMA_SERVER_BIN=llama-server
#VOICELAYER_LLAMA_MODEL_PATH=/absolute/path/to/model.gguf
#VOICELAYER_LLAMA_HF_REPO=
#VOICELAYER_LLAMA_SERVER_ARGS=
#VOICELAYER_LLAMA_LAUNCH_TIMEOUT_SECONDS=45
#VOICELAYER_LLAMA_POLL_INTERVAL_SECONDS=0.5
